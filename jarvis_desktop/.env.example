# ── OPTION 1: Ollama (100% local, offline — recommended) ─────
# Install Ollama from https://ollama.com, then run: ollama pull llama3.2
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.2              # or: mistral, llama3.1, gemma2, phi3
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── OPTION 2: Cloud AI (requires internet + API key) ──────────
# You can use OpenAI (sk-...), Google Gemini (AIza...), or Groq (gsk_...)
# Groq and Gemini offer generous free tiers. Set OLLAMA_ENABLED=false to use cloud.
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o  # For free tier, this is auto-switched to gemini-1.5-flash or llama3-8b-8192

# Optional: ElevenLabs for premium voice
USE_ELEVENLABS=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Vision
VISION_ENABLED=true
CAMERA_INDEX=0

WAKE_WORD=hey jarvis
